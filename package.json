{
  "name": "datn-coolmate",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "test": "npx playwright test",
    "test:ci": "node scripts/run-ci-tests.mjs",
    "test:ui": "npx playwright test --ui",
    "test:debug": "npx playwright test --debug",
    "test:headed": "npx playwright test --headed",
    "test:allure": "npm run allure:clean && npx playwright test",
    "allure:clean": "node -e \"require('fs').rmSync('allure-results',{recursive:true,force:true});\"",
    "allure:clean-report": "node -e \"require('fs').rmSync('allure-report',{recursive:true,force:true});\"",
    "allure:history": "node -e \"const fs=require('fs'); fs.mkdirSync('allure-results',{recursive:true}); fs.rmSync('allure-results/history',{recursive:true,force:true}); if (fs.existsSync('allure-report/history')) fs.cpSync('allure-report/history','allure-results/history',{recursive:true});\"",
    "allure:generate": "npm run allure:history && allure generate allure-results --clean -o allure-report",
    "allure:open": "allure open allure-report",
    "allure:serve": "allure serve allure-results",
    "allure:report": "node allurerc.mjs"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/node": "^25.6.0",
    "allure-commandline": "^2.36.0",
    "allure-playwright": "^3.6.0"
  },
  "dependencies": {
    "dotenv": "^17.4.1"
  }
}
